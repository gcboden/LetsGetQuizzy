{
  "rules": {
    "users": {
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid"
      }
    },
    "quizzes": {
      "$quizId": {
        ".read": true,
        ".write": "auth != null"
      }
    },
    "games": {
      "$gamePin": {
        ".read": true,
        ".write": true,
        "players": {
          "$playerId": {
            ".write": true
          }
        },
        "answers": {
          ".write": true
        },
        "teams": {
          ".write": true
        }
      }
    },
    "userQuizzes": {
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid"
      }
    }
  }
}
